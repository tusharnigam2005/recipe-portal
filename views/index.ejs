<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head') %>
</head>
<body>
<%- include('partials/navbar') %>

<main>
  <!-- Hero -->
  <section class="hero container">
    <div class="hero__inner">
      <div class="hero__content">
        <span class="eyebrow hero__eyebrow">🍳 30 Recipes &middot; 8 Cuisines</span>
        <h1>Discover Delicious Recipes <span class="accent">From Around The World</span></h1>
        <p class="hero__subtitle">
          From smoky butter chicken to silky pasta alfredo — browse chef-tested recipes,
          filter by cuisine, and search instantly as you type.
        </p>

        <form class="search-bar" id="heroSearchForm" role="search">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input id="heroSearchInput" type="text" placeholder="Search for butter chicken, tacos, ramen..." aria-label="Search recipes" />
          <button type="submit">Search</button>
        </form>

        <div class="hero__actions">
          <a href="#recipes" class="btn btn--primary">Explore Recipes</a>
          <a href="/console" class="btn btn--outline">Open Developer Console →</a>
        </div>
      </div>

      <div class="hero__visual">
        <div class="hero-card">
          <img src="<%= recipes[0].image %>" alt="<%= recipes[0].title %>" />
          <div class="hero-badge">
            <div><strong><%= recipes[0].title %></strong><%= recipes[0].country %> &middot; <%= recipes[0].cookTime %></div>
          </div>
          <div class="hero-seal">★ <%= recipes[0].rating %><br/>RATED</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <div class="container">
    <div class="stats">
      <div class="stat">
        <div class="stat__value"><%= stats.recipeCount %></div>
        <div class="stat__label">Recipes</div>
      </div>
      <div class="stat">
        <div class="stat__value"><%= stats.categoryCount %></div>
        <div class="stat__label">Categories</div>
      </div>
      <div class="stat">
        <div class="stat__value">500+</div>
        <div class="stat__label">Ingredients</div>
      </div>
      <div class="stat">
        <div class="stat__value">API</div>
        <div class="stat__label">Ready</div>
      </div>
    </div>
  </div>

  <!-- Categories -->
  <section class="section" id="categories">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Browse by cuisine</span>
        <h2>Categories</h2>
        <p>Jump straight to the flavors you're craving.</p>
      </div>

      <div class="categories-grid">
        <%
        const categoryIcons = {
          Indian: "🍛", Italian: "🍝", Chinese: "🥢", Mexican: "🌮",
          Desserts: "🍰", Healthy: "🥗", "Fast Food": "🍔", Vegan: "🥕"
        };
        %>
        <% categories.forEach(cat => { %>
          <div class="category-chip" data-category="<%= cat %>">
            <div class="category-chip__icon"><%= categoryIcons[cat] || "🍽️" %></div>
            <div class="category-chip__name"><%= cat %></div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- Recipes -->
  <section class="section section--tight" id="recipes">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Popular right now</span>
        <h2>Recipes worth cooking tonight</h2>
        <p>Search live or filter by cuisine — the grid updates instantly.</p>
      </div>

      <div class="toolbar">
        <div class="search-bar" style="max-width: 340px; margin-top: 0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input id="searchInput" type="text" placeholder="Filter recipes..." aria-label="Filter recipes" />
        </div>

        <div class="filter-pills" id="filterPills">
          <button class="filter-pill is-active" data-category="All">All</button>
          <% categories.forEach(cat => { %>
            <button class="filter-pill" data-category="<%= cat %>"><%= cat %></button>
          <% }) %>
        </div>
      </div>

      <div class="recipe-grid" id="recipeGrid">
        <% recipes.forEach(recipe => { %>
          <article class="recipe-card"
                    data-title="<%= recipe.title %>"
                    data-category="<%= recipe.category %>"
                    data-tags="<%= recipe.tags.join(' ') %>">
            <div class="recipe-card__media">
              <img src="<%= recipe.image %>" alt="<%= recipe.title %>" loading="lazy" />
              <span class="badge badge--cuisine"><%= recipe.category %></span>
              <span class="badge badge--difficulty badge--<%= recipe.difficulty %>"><%= recipe.difficulty %></span>
              <div class="recipe-card__seal"><%= recipe.rating %><small>RATING</small></div>
            </div>
            <div class="recipe-card__body">
              <h3 class="recipe-card__title"><%= recipe.title %></h3>
              <p class="recipe-card__desc"><%= recipe.description %></p>
              <div class="recipe-card__meta">
                <span>⏱ <%= recipe.cookTime %></span>
                <span>🌍 <%= recipe.country %></span>
              </div>
              <a href="/recipe/<%= recipe.slug %>" class="recipe-card__cta">
                Read Recipe <span>→</span>
              </a>
            </div>
          </article>
        <% }) %>

        <div class="empty-state" id="emptyState" style="display: none;">
          <h3>No recipes match your search</h3>
          <p>Try a different keyword or clear the category filter.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
